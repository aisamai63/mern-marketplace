{
  "info": {
    "_postman_id": "c8f9e1b2-5f4a-4e87-9a2e-2c1b0d7f3a11",
    "name": "MERN Marketplace Backend",
    "description": "Postman collection for auth and listing CRUD endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "register"]
        }
      },
      "response": []
    },
    {
      "name": "2. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res && res.data && res.data.token) {",
              "  pm.collectionVariables.set('token', res.data.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "3. Create Listing",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res && res.data && res.data._id) {",
              "  pm.collectionVariables.set('listingId', res.data._id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"iPhone 13\",\n  \"description\": \"128GB, excellent condition\",\n  \"price\": 650,\n  \"category\": \"Electronics\",\n  \"images\": [\"https://example.com/iphone.jpg\"],\n  \"location\": \"Toronto\",\n  \"status\": \"active\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/listings",
          "host": ["{{baseUrl}}"],
          "path": ["api", "listings"]
        }
      },
      "response": []
    },
    {
      "name": "4. Get Listings",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/listings",
          "host": ["{{baseUrl}}"],
          "path": ["api", "listings"]
        }
      },
      "response": []
    },
    {
      "name": "5. Update Listing",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"price\": 600,\n  \"description\": \"Price updated for quick sale\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/listings/{{listingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "listings", "{{listingId}}"]
        }
      },
      "response": []
    },
    {
      "name": "6. Delete Listing",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/listings/{{listingId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "listings", "{{listingId}}"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    },
    {
      "key": "userEmail",
      "value": "demo@example.com"
    },
    {
      "key": "userPassword",
      "value": "123456"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "listingId",
      "value": ""
    }
  ]
}
